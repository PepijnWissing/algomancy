class {{ class_name }}ETLFactory(SimpleETLFactory):
    """
    Factory for the {{ project_name }} ETL pipeline.

    Classmethod-based factory: every ``create_*`` hook is a classmethod so
    the factory carries no instance state. Delegate to ``super()`` for the
    framework defaults and only customise the bits that are specific to
    this project.

    TODO: Adapt each stage to your data.
    """

    @classmethod
    def create_extraction_sequence(
        cls,
        files: Dict[str, File] | None = None,
        schemas: Dict[str, Schema] | None = None,
        logger: Optional[Logger] = None,
    ) -> ExtractionSequence:
        """
        Default extraction defers to the schema registry: each registered
        ``(extension, schema_type)`` pair maps to an extractor class, and
        ``super()`` builds them straight from your schemas.

        Override only for files that need non-default extractor parameters
        (custom CSV separator, explicit XLSX sheet, …):

            sequence = super().create_extraction_sequence(default_files, schemas, logger)
            sequence.add_extractor(
                CSVSingleExtractor(
                    file=files["my_file"],
                    schema=schemas["my_file"],
                    separator=";",
                    logger=logger,
                )
            )
            return sequence
        """
        return super().create_extraction_sequence(files, schemas, logger)

    @classmethod
    def create_validation_sequence(
        cls,
        schemas: Dict[str, Schema],
        logger: Optional[Logger] = None,
    ) -> ValidationSequence:
        """
        ``super()`` already adds ``RequiredColumnsValidator`` +
        ``SchemaValidator`` + ``PrimaryKeyValidator``. Add project-specific
        validators here.

        Example:

            sequence = super().create_validation_sequence(schemas, logger)
            sequence.add_validator(
                MissingValueValidator(
                    table="my_table",
                    columns=["name", "email"],
                    severity=ValidationSeverity.ERROR,
                )
            )
            return sequence
        """
        return super().create_validation_sequence(schemas, logger)

